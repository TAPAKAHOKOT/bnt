BNT_MAX_REQUEST_BYTES=716800
BNT_MAX_RESPONSE_BYTES=1000000
BNT_MAX_RESPONSE_DURATION_MS=30000
BNT_AUDIO_SAMPLE_RATE=16000
BNT_AUDIO_CHANNELS=1
BNT_AUDIO_BITS_PER_SAMPLE=16
BNT_LOG_LEVEL=info
BNT_RESPONSE_TIMEOUT_MS=30000
BNT_CONVERSATION_TTL_MS=300000

# Shared secret the device must send as `Authorization: Bearer <token>`.
# Leave empty to disable auth (local dev/tests). Set it in production so the
# public endpoint is not open to everyone; the firmware's BNT_API_TOKEN must match.
BNT_API_TOKEN=

# OpenAI integration (backend only — never ship to firmware).
# Leave OPENAI_API_KEY empty to use the fake response service.
# Force a backend with BNT_RESPONSE_SERVICE=fake|openai.
BNT_RESPONSE_SERVICE=
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.5
OPENAI_STT_MODEL=whisper-1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=nova

# Give the chat model the built-in web_search tool (answers with up-to-date
# info; the model decides when to search). Set to 0/false to disable.
BNT_WEB_SEARCH=1
